# ============================================================================
# Environment Variables Configuration Guide
# ============================================================================
# This file documents ALL environment variables used in the project.
# Copy to .env.local (development) and fill in values.
#
# NAMING CONVENTION:
#   - VITE_* variables: Exposed to client-side code (Vite builds these in)
#   - Other variables: Server-side only (worker, build tools)
#
# NOTE: Production environment variables are configured in wrangler.jsonc
# and Cloudflare Secrets Store, not in .env files.
# ============================================================================

# ============================================================================
# CLIENT & AUTHENTICATION
# ============================================================================

# Neon Database Authentication URL (Development Only)
# Used by: Client-side auth initialization, Worker auth middleware
# Production: Uses NEON_AUTH secret from Cloudflare Secrets Store (configured in wrangler.jsonc)
# Example: https://ep-lively-union-afo9aw2b.neonauth.c-2.us-west-2.aws.neon.tech/neondb/auth
VITE_NEON_AUTH_URL=https://your-neon-auth-endpoint

# ============================================================================
# DATABASE - LOCAL DEVELOPMENT & CLOUDFLARE TESTING
# ============================================================================

# Cloudflare Hyperdrive Local Connection String (Development Only)
# Used by: Drizzle ORM migrations, build tools, local schema generation, local Cloudflare testing
# Production: Uses Cloudflare Hyperdrive binding configured in wrangler.jsonc
# Example: postgres://username:password@localhost:5432/job_journal
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://username:password@localhost:5432/database

# ============================================================================
# CLOUDFLARE WORKERS PRODUCTION BINDINGS (Reference Only)
# ============================================================================
# These bindings are NOT defined here. They're configured in wrangler.jsonc.
# Listed here for documentation:
#
# HYPERDRIVE Binding
#   - Cloudflare Hyperdrive connection to PostgreSQL
#   - Binding ID: 5b3894005d3e44b78b66bfbf10f567c8
#   - Usage: Database connections in production (src/worker/db/index.ts)
#
# NEON_AUTH Secret Store
#   - Stores the production VITE_NEON_AUTH_URL securely
#   - Store ID: 7f34c44a845b4671a6e140243cf91eeb
#   - Updated separately in Cloudflare dashboard
#
# See wrangler.jsonc for binding configuration details.

# ============================================================================
# ADDING NEW VARIABLES - CHECKLIST
# ============================================================================
#
# For client-side variables (add VITE_ prefix):
#   [ ] Add to this file (.env.example)
#   [ ] Add to .env.local
#   [ ] If needed in production, add to Cloudflare Secrets Store via dashboard
#   [ ] Add to wrangler.jsonc if it's a binding or secret
#   [ ] Update relevant source files to use import.meta.env.VITE_*
#
# For server-side variables only:
#   [ ] Add to this file (.env.example) with "dev only" or "production only" note
#   [ ] Add to .env.local as needed
#   [ ] If sensitive in production, add as secret in Cloudflare dashboard
#   [ ] Update relevant source files
#
# ============================================================================
